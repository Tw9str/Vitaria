generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url = env("DATABASE_URL")
}

enum Role {
  admin
  editor
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  role          Role      @default(editor)
  blocked       Boolean   @default(false)

  accounts      Account[]
  sessions      Session[]

  // Back-relations
  createdProducts  Product[]     @relation("ProductCreatedBy")
  createdNotes     Note[]        @relation("NoteAuthor")
  updatedLeadNotes Lead[]        @relation("LeadNotesUpdatedBy")
  activityLogs     ActivityLog[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(auto()) @map("_id") @db.ObjectId
  userId             String  @db.ObjectId
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

type ProductSection {
  heading String
  items   String[]
}

type ProductSpec {
  label String
  value String
}

model Product {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  slug      String   @unique
  title     String
  summary   String
  highlight String?
  image String
  gallery   String[] @default([])
  sections  ProductSection[]
  specs     ProductSpec[]
  published Boolean  @default(false)

  createdById String? @db.ObjectId
  createdBy   User?   @relation("ProductCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String
  company   String?
  website   String?
  type      String
  region    String
  message   String
  ip        String?
  userAgent String?
  referrer  String?
  status    String   @default("new")
  notes     String?

  notesUpdatedById String? @db.ObjectId
  notesUpdatedBy   User?   @relation("LeadNotesUpdatedBy", fields: [notesUpdatedById], references: [id])

  createdAt DateTime @default(now())
}

model Note {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   String
  pinned    Boolean  @default(false)

  authorId    String? @db.ObjectId
  author      User?   @relation("NoteAuthor", fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Site configuration (singleton, id = "main") ──────────────────────────
type ContactChannel {
  value   String
  visible Boolean @default(true)
}

model SiteConfig {
  id                 String          @id @default("main") @map("_id")
  email              ContactChannel?
  phone              ContactChannel?
  whatsapp           ContactChannel?
  facebook           ContactChannel?
  instagram          ContactChannel?
  twitter            ContactChannel?
  linkedin           ContactChannel?
  whatsIncludedTitle String?
  whatsIncludedItems Json?
  updatedAt          DateTime        @updatedAt
}

// severity: "info" | "warning" | "error"
model ActivityLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  action      String   // e.g. PRODUCT_CREATED, LEAD_STATUS_CHANGED
  entity      String   // product | lead | user | note | profile
  entityId    String?
  entityTitle String?
  actorEmail  String
  actorName   String?
  actorId     String?  @db.ObjectId
  actor       User?    @relation(fields: [actorId], references: [id])
  severity    String   @default("info")
  detail      String?
  createdAt   DateTime @default(now())
}